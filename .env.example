# ============================================================================
#  Magdalene Medza — environment variables
#  Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ============================================================================

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Neon or Supabase. Use the POOLED connection string for DATABASE_URL (runtime)
# and the DIRECT connection string for DIRECT_URL (migrations).
#   Neon:     DATABASE_URL = the "-pooler" host;  DIRECT_URL = the direct host
#   Supabase: DATABASE_URL = port 6543 (pooler);  DIRECT_URL = port 5432
DATABASE_URL="postgresql://user:pass@HOST-pooler/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@HOST/db?sslmode=require"

# ── File uploads (Vercel Blob) ──────────────────────────────────────────────
# Create a Blob store in Vercel → Storage; this token is added automatically.
# If unset (local dev), uploads fall back to ./public/uploads.
BLOB_READ_WRITE_TOKEN=""

# ── Auth (CRITICAL) ─────────────────────────────────────────────────────────
# Secret used to sign the admin session JWT. MUST be long and random.
# A weak/missing secret lets anyone forge an admin login (the app refuses to
# start in production if this is shorter than 32 characters).
# Generate one with:   openssl rand -base64 48
AUTH_SECRET="change-me-run-openssl-rand-base64-48"

# ── Admin account (used only when seeding) ──────────────────────────────────
ADMIN_EMAIL="owner@example.com"
ADMIN_PASSWORD="use-a-strong-passphrase"

# ── Business details (used when seeding the database) ───────────────────────
SALON_NAME="Magdalene Medza"
SALON_LOCATION="Your studio address"
WHATSAPP_NUMBER="+254700000000"
OWNER_EMAIL="owner@example.com"

# ── Booking email (Web3Forms) ───────────────────────────────────────────────
# Web3Forms' free plan only accepts submissions from the browser, so the email
# is sent client side and the key is exposed to the client by design (it can
# only deliver mail to your own inbox, never read anything).
WEB3FORMS_ACCESS_KEY=""
NEXT_PUBLIC_WEB3FORMS_KEY=""
NEXT_PUBLIC_OWNER_EMAIL="owner@example.com"

# ── Footer credit ───────────────────────────────────────────────────────────
DEV_WHATSAPP="+254700000000"

# ── Production only (optional) ──────────────────────────────────────────────
# Comma separated list of origins allowed to call the API (CORS). Leave unset
# to keep the API same origin only (recommended).
# ALLOWED_ORIGINS="https://your-domain.com"
